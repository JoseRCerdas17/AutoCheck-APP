{
  "expo": {
    "name": "AutoCheck",
    "slug": "autocheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoAutoCheck.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/LogoAutoCheck.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.autocheck.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoAutoCheck.png",
        "backgroundColor": "#0D1117"
      },
      "package": "com.autocheck.app"
    },
    "web": {
      "favicon": "./assets/LogoAutoCheck.png"
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "678a9f60-85d7-4370-9629-d13a9910f8f1"
      }
    },
    "owner": "josercc1117"
  }
}